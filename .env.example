# OneBook AI Environment Variables
# Copy this file to .env and fill in your values.
# This file keeps only common local-development settings.
# For advanced options, see README.md.

# ===================
# Database
# ===================
DATABASE_URL=postgres://onebook:onebook@localhost:5432/onebook?sslmode=disable

# ===================
# Redis (refresh token + revoke state)
# ===================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ===================
# JWT Authentication (RS256)
# ===================
# run.sh resolves relative paths from repo root and auto-generates keys if missing.
JWT_PRIVATE_KEY_PATH=secrets/jwt/private.pem
JWT_PUBLIC_KEY_PATH=secrets/jwt/public.pem
JWT_KEY_ID=jwt-active
JWT_ISSUER=onebook-auth
JWT_AUDIENCE=onebook-api
JWT_LEEWAY=30s

# ===================
# CORS (frontend dev server + cookie auth)
# ===================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8086
CORS_ALLOW_CREDENTIALS=true

# ===================
# MinIO Object Storage
# ===================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=onebook
MINIO_SECRET_KEY=onebook123
MINIO_BUCKET=onebook
MINIO_USE_SSL=false

# ===================
# Internal Service JWT (RS256)
# ===================
ONEBOOK_INTERNAL_JWT_PRIVATE_KEY_PATH=secrets/internal-jwt/private.pem
ONEBOOK_INTERNAL_JWT_PUBLIC_KEY_PATH=secrets/internal-jwt/public.pem
ONEBOOK_INTERNAL_JWT_KEY_ID=internal-active

# ===================
# Text Generation (LLM)
# ===================
# GENERATION_PROVIDER selects the generation backend:
#   gemini        – Google Gemini (default, needs GENERATION_API_KEY)
#   ollama        – local Ollama /api/chat
#   openai-compat – any OpenAI-compatible /v1/chat/completions endpoint
GENERATION_PROVIDER=gemini
GENERATION_API_KEY=your-api-key-here
GENERATION_MODEL=gemini-2.5-flash
# GENERATION_BASE_URL=http://localhost:8000/v1

# ===================
# Retrieval
# ===================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=onebook_chunks
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=onebook_lexical_chunks
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=

# ===================
# Canonical Embedding Dimension
# ===================
ONEBOOK_EMBEDDING_DIM=3072

# ===================
# Ingest chunking
# ===================
INGEST_CHUNK_SIZE=480
INGEST_CHUNK_OVERLAP=80
INGEST_LEXICAL_CHUNK_SIZE=160
INGEST_LEXICAL_CHUNK_OVERLAP=30
INGEST_SEMANTIC_CHUNK_SIZE=480
INGEST_SEMANTIC_CHUNK_OVERLAP=80

# ===================
# Chat retrieval
# ===================
CHAT_DENSE_RECALL_TOPK=40
CHAT_LEXICAL_RECALL_TOPK=60
CHAT_DENSE_WEIGHT=0.45
CHAT_LEXICAL_WEIGHT=0.55
CHAT_FUSION_TOPK=30
CHAT_RETRIEVAL_MODE=hybrid_best
RERANKER_URL=http://localhost:8088/rerank
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_REVISION=
RERANKER_CACHE_DIR=/models/huggingface
RERANKER_SENTENCE_TRANSFORMERS_HOME=/models/huggingface/sentence-transformers
RERANKER_MAX_DOCS=50
RERANKER_MAX_CHARS=2400
RERANKER_BATCH_SIZE=8

# ===================
# Optional OCR fallback for scanned PDF
# ===================
# Docker OCR service — started automatically by run.sh / start-backend.sh
INGEST_OCR_ENABLED=true
INGEST_OCR_SERVICE_URL=http://localhost:8087
# CLI fallback (used only when OCR_SERVICE_URL is not set)
# INGEST_OCR_COMMAND=paddleocr
INGEST_OCR_DEVICE=cpu
INGEST_OCR_TIMEOUT_SECONDS=300
INGEST_PDF_MIN_PAGE_RUNES=80
INGEST_PDF_MIN_PAGE_SCORE=0.45
INGEST_PDF_OCR_MIN_SCORE_DELTA=0.08

# ===================
# Logging
# ===================
# Directory for log files. start-backend.sh resolves this to an absolute path.
LOGS_DIR=backend/logs

# ===================
# Ollama (local embedding provider)
# ===================
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:latest

# ===================
# Chat retrieval tuning
# ===================
# Feature flags: set to false to disable the corresponding strategy.
CHAT_QUERY_REWRITE_ENABLED=true
CHAT_MULTI_QUERY_ENABLED=true
CHAT_RERANK_TOPN=12
CHAT_CONTEXT_BUDGET=2200
CHAT_MIN_EVIDENCE_COUNT=2
CHAT_ABSTAIN_ENABLED=true

# ===================
# Admin eval center
# ===================
AUTH_EVAL_STORAGE_DIR=data/eval-center
AUTH_EVAL_WORKER_POLL_INTERVAL=3s
